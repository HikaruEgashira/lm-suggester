{
  "template": [
    {
      "filePath": null,
      "messages": [],
      "suppressedMessages": [],
      "errorCount": 0,
      "warningCount": 0,
      "fatalErrorCount": 0,
      "fixableErrorCount": 0,
      "fixableWarningCount": 0,
      "source": null
    }
  ],
  "mappings": [
    {
      "target": "$[0].filePath",
      "source": "input.filePath"
    },
    {
      "target": "$[0].messages[0].ruleId",
      "source": "input.sourceName",
      "default": "reviewdog-converter"
    },
    {
      "target": "$[0].messages[0].severity",
      "source": "input.severity",
      "transform": "to_eslint_severity",
      "default": "1"
    },
    {
      "target": "$[0].messages[0].message",
      "source": "input.message",
      "default": "Code suggestion"
    },
    {
      "target": "$[0].messages[0].line",
      "source": "core.StartLine"
    },
    {
      "target": "$[0].messages[0].column",
      "source": "core.StartColumn"
    },
    {
      "target": "$[0].messages[0].endLine",
      "source": "core.EndLine"
    },
    {
      "target": "$[0].messages[0].endColumn",
      "source": "core.EndColumn"
    },
    {
      "target": "$[0].messages[0].fix.range[0]",
      "source": "core.StartOffset",
      "default": "0"
    },
    {
      "target": "$[0].messages[0].fix.range[1]",
      "source": "core.EndOffset",
      "default": "0"
    },
    {
      "target": "$[0].messages[0].fix.text",
      "source": "core.After"
    },
    {
      "target": "$[0].source",
      "source": "input.baseText"
    }
  ]
}