Output examples/e2e/help-command.gif
Set FontSize 14
Set Width 1200
Set Height 800
Set Theme "Catppuccin Mocha"
Set Padding 20

# lm-suggester main help command
Type "lm-suggester --help"
Sleep 500ms
Enter
Sleep 2.5s

# Clear screen and show version command help
Type "clear"
Sleep 200ms
Enter
Sleep 500ms

Type "lm-suggester version --help"
Sleep 500ms
Enter
Sleep 2s
